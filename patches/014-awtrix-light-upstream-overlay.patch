+String DisplayManager_::getAppsWithIcon()
+{
+  DynamicJsonDocument jsonDocument(4096);
+  JsonArray jsonArray = jsonDocument.to<JsonArray>();
+  std::set<String> enabledApps;
+
+  for (const auto &app : Apps)
+  {
+    JsonObject appObject = jsonArray.createNestedObject();
+    appObject["name"] = app.first;
+    appObject["enabled"] = true;
+    enabledApps.insert(app.first);
+
+    CustomApp *customApp = getCustomAppByName(app.first);
+    if (customApp != nullptr)
+    {
+      appObject["icon"] = customApp->iconName;
+      appObject["type"] = customApp->flowRefresh ? "flow" : "custom";
+    }
+  }
+
+  auto addDisabledNativeApp = [&](const String &name)
+  {
+    if (enabledApps.find(name) != enabledApps.end())
+      return;
+
+    JsonObject appObject = jsonArray.createNestedObject();
+    appObject["name"] = name;
+    appObject["enabled"] = false;
+  };
+
+  addDisabledNativeApp("Time");
+  addDisabledNativeApp("Date");
+  addDisabledNativeApp("Temperature");
+  addDisabledNativeApp("Humidity");
+#ifdef ULANZI
+  addDisabledNativeApp("Battery");
+#endif
+
+  for (const auto &customAppEntry : customApps)
+  {
+    if (enabledApps.find(customAppEntry.first) != enabledApps.end())
+      continue;
+
+    const CustomApp &customApp = customAppEntry.second;
+    JsonObject appObject = jsonArray.createNestedObject();
+    appObject["name"] = customAppEntry.first;
+    appObject["enabled"] = false;
+    appObject["icon"] = customApp.iconName;
+    appObject["type"] = customApp.flowRefresh ? "flow" : "custom";
+  }
+
+  String jsonString;
+  serializeJson(jsonArray, jsonString);
+  return jsonString;
+}
