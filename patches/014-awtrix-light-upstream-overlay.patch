+bool parseFragmentsText(const JsonArray &fragmentArray, std::vector<uint32_t> &colors, std::vector<String> &fragments, uint32_t standardColor)
+{
+  colors.clear();
+  fragments.clear();
+
+  for (JsonObject fragmentObj : fragmentArray)
+  {
+    String textFragment = fragmentObj["t"];
+    uint32_t color;
+    if (fragmentObj.containsKey("c"))
+    {
+      auto fragColor = fragmentObj["c"];
+      color = getColorFromJsonVariant(fragColor, standardColor);
+    }
+    else
+    {
+      color = standardColor;
+    }
+
+    fragments.push_back(utf8ascii(textFragment));
+    colors.push_back(color);
+  }
+  return true;
+}
+
+String flowInputValue(JsonObject doc, const String &id)
+{
+  if (!doc.containsKey("inputs") || !doc["inputs"].is<JsonArray>())
+    return "";
+
+  for (JsonObject input : doc["inputs"].as<JsonArray>())
+  {
+    if (input["id"].as<String>() == id)
+      return input["value"].as<String>();
+  }
+  return "";
+}
+
+String flowApplyInputs(JsonObject doc, String value)
+{
+  int start = 0;
+  while ((start = value.indexOf("{{", start)) != -1)
+  {
+    int end = value.indexOf("}}", start);
+    if (end == -1)
+      break;
+
+    String key = value.substring(start + 2, end);
+    String replacement = flowInputValue(doc, key);
+    value.replace("{{" + key + "}}", replacement);
+    start += replacement.length();
+  }
+  return value;
+}
+
+String flowJsonPath(JsonVariant value, const String &path)
+{
+  JsonVariant current = value;
+  int start = 0;
+  while (start < path.length())
+  {
+    int dot = path.indexOf('.', start);
+    String key = dot == -1 ? path.substring(start) : path.substring(start, dot);
+    if (!current.is<JsonObject>() || !current.as<JsonObject>().containsKey(key))
+      return "";
+
+    current = current.as<JsonObject>()[key];
+    if (dot == -1)
+      break;
+    start = dot + 1;
+  }
+
+  if (current.is<const char *>())
+    return current.as<String>();
+  if (current.is<long>() || current.is<int>() || current.is<float>() || current.is<double>())
+    return current.as<String>();
+  if (current.is<bool>())
+    return current.as<bool>() ? "true" : "false";
+  return "";
+}
+
+void flowReplaceTokens(String &text, JsonDocument &sourceValues)
+{
+  int start = 0;
+  while ((start = text.indexOf("{{", start)) != -1)
+  {
+    int end = text.indexOf("}}", start);
+    if (end == -1)
+      break;
+
+    String path = text.substring(start + 2, end);
+    String replacement = flowJsonPath(sourceValues.as<JsonVariant>(), path);
+    if (replacement.length() == 0)
+      replacement = "N/A";
+    text.replace("{{" + path + "}}", replacement);
+    start += replacement.length();
+  }
+}
+
+bool isAllowedBilibiliSource(const String &url)
+{
+  return url.startsWith("https://api.bilibili.com/x/relation/stat?vmid=") &&
+         url.indexOf("&jsonp=jsonp") > 0 &&
+         url.indexOf("#") == -1 &&
+         url.indexOf("@") == -1;
+}
+
+void fetchFlowHttpSource(JsonObject app, JsonObject source, DynamicJsonDocument &sourceValues)
+{
+  String id = source["id"].as<String>();
+  String url = flowApplyInputs(app, source["url"].as<String>());
+  if (id.length() == 0 || url.length() == 0)
+    return;
+  if (!isAllowedBilibiliSource(url))
+    return;
+
+  HTTPClient http;
+  WiFiClientSecure secureClient;
+  bool ok = false;
+  secureClient.setCACert(bilibiliRootCACertificate);
+  ok = http.begin(secureClient, url);
+  if (!ok)
+    return;
+
+  uint16_t timeout = source.containsKey("timeout") ? source["timeout"].as<uint16_t>() : 5000;
+  http.setTimeout(timeout > 5000 ? 5000 : timeout);
+
+  int code = http.GET();
+  if (code == HTTP_CODE_OK)
+  {
+    String body = http.getString();
+    if (body.length() > 4096)
+    {
+      http.end();
+      return;
+    }
+    if (source["responseType"].as<String>() == "json")
+    {
+      DynamicJsonDocument response(4096);
+      if (deserializeJson(response, body) == DeserializationError::Ok)
+        sourceValues[id].set(response.as<JsonVariant>());
+    }
+    else
+    {
+      sourceValues[id] = body;
+    }
+  }
+  http.end();
+}
+
+String flowUrlEncode(const String &value)
+{
+  String encoded;
+  const char *hex = "0123456789ABCDEF";
+  for (size_t i = 0; i < value.length(); i++)
+  {
+    char c = value.charAt(i);
+    if (isalnum(c) || c == '-' || c == '_' || c == '.' || c == '~')
+    {
+      encoded += c;
+    }
+    else
+    {
+      encoded += '%';
+      encoded += hex[(c >> 4) & 0x0F];
+      encoded += hex[c & 0x0F];
+    }
+  }
+  return encoded;
+}
+
+bool isAllowedHomeAssistantEntity(const String &entity)
+{
+  if (entity.length() == 0 || entity.length() > 96)
+    return false;
+  if (entity.indexOf('/') >= 0 || entity.indexOf('\\') >= 0 || entity.indexOf('#') >= 0 || entity.indexOf('?') >= 0)
+    return false;
+  return entity.indexOf('.') > 0;
+}
+
+void fetchFlowHaSource(JsonObject app, JsonObject source, DynamicJsonDocument &sourceValues)
+{
+  String id = source["id"].as<String>();
+  String entity = flowApplyInputs(app, source["entity"].as<String>());
+  String baseUrl = HA_BASE_URL;
+  baseUrl.trim();
+  while (baseUrl.endsWith("/"))
+    baseUrl.remove(baseUrl.length() - 1);
+
+  if (id.length() == 0 || !isAllowedHomeAssistantEntity(entity) || HA_TOKEN.length() == 0)
+    return;
+  if (!baseUrl.startsWith("http://"))
+    return;
+
+  HTTPClient http;
+  WiFiClient client;
+  String url = baseUrl + "/api/states/" + flowUrlEncode(entity);
+  if (!http.begin(client, url))
+    return;
+
+  uint16_t timeout = source.containsKey("timeout") ? source["timeout"].as<uint16_t>() : 5000;
+  http.setTimeout(timeout > 5000 ? 5000 : timeout);
+  http.addHeader("Authorization", "Bearer " + HA_TOKEN);
+  http.addHeader("Accept", "application/json");
+
+  int code = http.GET();
+  if (code == HTTP_CODE_OK)
+  {
+    String body = http.getString();
+    if (body.length() <= 4096)
+    {
+      DynamicJsonDocument response(4096);
+      if (deserializeJson(response, body) == DeserializationError::Ok)
+        sourceValues[id].set(response.as<JsonVariant>());
+    }
+  }
+  http.end();
+}
+
+
+uint32_t flowRefreshInterval(JsonObject doc)
+{
+  uint32_t interval = 0;
+  if (!doc.containsKey("sources") || !doc["sources"].is<JsonArray>())
+    return 0;
+
+  for (JsonObject source : doc["sources"].as<JsonArray>())
+  {
+    String type = source["type"].as<String>();
+    if (type == "http")
+    {
+      String url = flowApplyInputs(doc, source["url"].as<String>());
+      if (!isAllowedBilibiliSource(url))
+        continue;
+    }
+    else if (type == "ha")
+    {
+      String entity = flowApplyInputs(doc, source["entity"].as<String>());
+      if (!isAllowedHomeAssistantEntity(entity) || HA_BASE_URL.length() == 0 || HA_TOKEN.length() == 0)
+        continue;
+    }
+    else
+    {
+      continue;
+    }
+    uint32_t seconds = source.containsKey("interval") ? source["interval"].as<uint32_t>() : 300;
+    if (seconds < 60)
+      seconds = 60;
+    uint32_t millisInterval = seconds * 1000UL;
+    if (interval == 0 || millisInterval < interval)
+      interval = millisInterval;
+  }
+  return interval;
+}
+
+void resolveFlowDisplay(JsonObject doc)
+{
+  if (!doc.containsKey("display") || !doc["display"].is<JsonObject>())
+    return;
+
+  JsonObject display = doc["display"].as<JsonObject>();
+  if (display.containsKey("icon") && !doc.containsKey("icon"))
+    doc["icon"] = display["icon"];
+  if (display.containsKey("color"))
+    doc["color"] = display["color"];
+  if (display.containsKey("background"))
+    doc["background"] = display["background"];
+  if (display.containsKey("progress"))
+    doc["progress"] = display["progress"];
+  if (display.containsKey("progressC"))
+    doc["progressC"] = display["progressC"];
+  if (display.containsKey("progressBC"))
+    doc["progressBC"] = display["progressBC"];
+
+  if (!display.containsKey("text"))
+    return;
+
+  String text = display["text"].as<String>();
+  DynamicJsonDocument sourceValues(4096);
+  if (doc.containsKey("sources") && doc["sources"].is<JsonArray>())
+  {
+    for (JsonObject source : doc["sources"].as<JsonArray>())
+    {
+      String type = source["type"].as<String>();
+      if (type == "http")
+        fetchFlowHttpSource(doc, source, sourceValues);
+      else if (type == "ha")
+        fetchFlowHaSource(doc, source, sourceValues);
+    }
+  }
+  flowReplaceTokens(text, sourceValues);
+  doc["text"] = text;
+}
+
+bool DisplayManager_::parseCustomPage(const String &name, const char *json, bool preventSave)
+{
+  if ((strcmp(json, "") == 0) || (strcmp(json, "{}") == 0))
+  {
+    removeCustomAppFromApps(name, true);
+    return true;
+  }
+
+  DynamicJsonDocument doc(8192);
+  DeserializationError error = deserializeJson(doc, json);
+  if (error)
+  {
+    DEBUG_PRINTLN(error.c_str());
+    doc.clear();
+    return false;
+  }
+
+  if (doc.is<JsonObject>())
+  {
+    JsonObject rootObj = doc.as<JsonObject>();
+    return generateCustomPage(name, rootObj, preventSave);
+  }
+  else if (doc.is<JsonArray>())
+  {
+    JsonArray customPagesArray = doc.as<JsonArray>();
+    int cpIndex = 0;
+    for (JsonObject customPageObject : customPagesArray)
+    {
+      generateCustomPage(name + String(cpIndex), customPageObject, preventSave);
+      ++cpIndex;
+    }
+  }
+
+  doc.clear();
+  return true;
+}
+DisplayManager_::CustomAppInstallResult DisplayManager_::installCustomAppFromJson(const String &name, const char *json)
+{
+  if (LittleFS.exists("/CUSTOMAPPS/" + name + ".json"))
+  {
+    return CUSTOM_APP_INSTALL_DUPLICATE;
+  }
+
+  for (const auto &app : Apps)
+  {
+    if (app.first == name || ((name == "demo-clock" || name == "Demo Clock") && (app.first == "demo-clock" || app.first == "Demo Clock")))
+    {
+      return CUSTOM_APP_INSTALL_DUPLICATE;
+    }
+  }
+
+  bool installed = parseCustomPage(name, json, false);
+
+  if (!installed)
+  {
+    return CUSTOM_APP_INSTALL_SAVE_FAILED;
+  }
+
+  ui->setApps(Apps);
+  ui->forceResetState();
+
+  return CUSTOM_APP_INSTALL_OK;
+}
+
+static bool validCustomAppName(const String &name)
+{
+  if (name.length() == 0 || name.length() > 64 || name.indexOf('/') >= 0 || name.indexOf('\\') >= 0 || name.indexOf("..") >= 0)
+    return false;
+  for (size_t i = 0; i < name.length(); i++)
+  {
+    char c = name[i];
+    bool valid = (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z') || (c >= '0' && c <= '9') || c == '_' || c == '-' || c == '.';
+    if (!valid)
+      return false;
+  }
+  return true;
+}
+
+void DisplayManager_::refreshFlowApp(const String &name)
+{
+  if (!validCustomAppName(name))
+    return;
+
+  String fileName = "/CUSTOMAPPS/" + name + ".json";
+  if (!LittleFS.exists(fileName))
+    return;
+
+  File file = LittleFS.open(fileName, "r");
+  if (!file)
+    return;
+  String json = "";
+  while (file.available())
+    json += char(file.read());
+  file.close();
+  parseCustomPage(name, json.c_str(), true);
+}
+
+bool DisplayManager_::uninstallCustomApp(const String &name)
+{
+  if (!validCustomAppName(name))
+    return false;
+  return parseCustomPage(name, "{}", false);
+}
