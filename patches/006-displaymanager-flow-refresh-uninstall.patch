+void DisplayManager_::refreshFlowApp(const String &name)
+{
+  String fileName = "/CUSTOMAPPS/" + name + ".json";
+  if (!LittleFS.exists(fileName))
+    return;
+
+  File file = LittleFS.open(fileName, "r");
+  if (!file)
+    return;
+  String json = "";
+  while (file.available())
+    json += char(file.read());
+  file.close();
+  parseCustomPage(name, json.c_str(), true);
+}
+
+bool DisplayManager_::uninstallCustomApp(const String &name)
+{
+  return parseCustomPage(name, "{}", false);
+}
 
 
 
