index 0000000..2621e05
--- /dev/null
+++ b/tools/build_app_js.py
@@ -0,0 +1,38 @@
+#!/usr/bin/env python3
+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parents[1]
+SRC = ROOT / "www/src/app"
+OUT = ROOT / "www/app.js"
+
+MODULES = [
+    "00-state-i18n.js",
+    "01-app-uninstall.js",
+    "02-cast-labels.js",
+    "03-cast-files-install.js",
+    "04-settings-state.js",
+    "05-settings-tabs-labels.js",
+    "06-device-setting-groups.js",
+    "07-legacy-setting-groups.js",
+    "08-settings-tabs-render.js",
+    "09-settings-field.js",
+    "10-settings-render-wifi.js",
+    "11-settings-load-save.js",
+    "12-settings-collect.js",
+    "13-legacy-save.js",
+    "14-device-save.js",
+    "15-cast-runtime-preview-bootstrap.js",
+]
+
+
+def main() -> None:
+    files = [SRC / name for name in MODULES]
+    missing = [str(path.relative_to(ROOT)) for path in files if not path.exists()]
+    if missing:
+        raise SystemExit("missing app source module(s): " + ", ".join(missing))
+    OUT.write_text("\n".join(path.read_text().rstrip("\n") for path in files) + "\n")
+
+
+if __name__ == "__main__":
+    main()
diff --git a/tools/cors_static_server.py b/tools/cors_static_server.py
new file mode 100644
index 0000000..3d1b60d
--- /dev/null
+++ b/tools/cors_static_server.py
@@ -0,0 +1,17 @@
+import http.server
+import socketserver
+
+class Handler(http.server.SimpleHTTPRequestHandler):
+    def end_headers(self):
+        self.send_header('Access-Control-Allow-Origin', '*')
+        self.send_header('Access-Control-Allow-Methods', 'GET, OPTIONS')
+        self.send_header('Access-Control-Allow-Headers', 'Content-Type')
+        super().end_headers()
+
+    def do_OPTIONS(self):
+        self.send_response(204)
+        self.end_headers()
+
+socketserver.TCPServer.allow_reuse_address = True
+with socketserver.TCPServer(('0.0.0.0', 8091), Handler) as httpd:
+    httpd.serve_forever()
diff --git a/tools/embed_www_assets.py b/tools/embed_www_assets.py
new file mode 100755
index 0000000..b56e1bd
--- /dev/null
+++ b/tools/embed_www_assets.py
@@ -0,0 +1,48 @@
+#!/usr/bin/env python3
+from pathlib import Path
+import gzip
+
+ROOT = Path(__file__).resolve().parents[1]
+GZIP_ASSETS = [
+    ("app_html", ROOT / "www/app.html", "text/html; charset=utf-8"),
+    ("app_css", ROOT / "www/app.css", "text/css; charset=utf-8"),
+    ("app_js", ROOT / "www/app.js", "application/javascript; charset=utf-8"),
+]
+RAW_ASSETS = [
+    ("app_icon", ROOT / "www/icon.png", "image/png"),
+]
+OUT = ROOT / "src/web_assets.h"
+
+
+def bytes_literal(data: bytes) -> str:
+    lines = []
+    for i in range(0, len(data), 16):
+        chunk = data[i:i + 16]
+        lines.append("  " + ", ".join(f"0x{b:02x}" for b in chunk) + ",")
+    return "\n".join(lines)
+
+
+def main() -> None:
+    parts = ["#pragma once", "#include <Arduino.h>", ""]
+    for name, path, content_type in GZIP_ASSETS:
+        raw = path.read_bytes()
+        gz = gzip.compress(raw, compresslevel=9, mtime=0)
+        parts.append(f"static const char {name}_content_type[] PROGMEM = {content_type!r};")
+        parts.append(f"static const uint8_t {name}_gz[] PROGMEM = {{")
+        parts.append(bytes_literal(gz))
+        parts.append("};")
+        parts.append(f"static const size_t {name}_gz_len = sizeof({name}_gz);")
+        parts.append("")
+    for name, path, content_type in RAW_ASSETS:
+        raw = path.read_bytes()
+        parts.append(f"static const char {name}_content_type[] PROGMEM = {content_type!r};")
+        parts.append(f"static const uint8_t {name}[] PROGMEM = {{")
+        parts.append(bytes_literal(raw))
+        parts.append("};")
+        parts.append(f"static const size_t {name}_len = sizeof({name});")
+        parts.append("")
+    OUT.write_text("\n".join(parts).replace("'", '"') + "\n")
+
+
+if __name__ == "__main__":
+    main()
