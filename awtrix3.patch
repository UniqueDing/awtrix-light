+const fs = require('fs');
+
+const manifestPath = process.argv[2] || 'mock-app-store/apps/steam-game.json';
+const payload = process.argv[3]
+  ? JSON.parse(process.argv[3])
+  : { state: 'Half-Life 2', attributes: { game: 'Half-Life 2' } };
+
+function jsonPathValue(value, path) {
+  for (const key of path.split('.')) {
+    if (!value || typeof value !== 'object' || !(key in value)) return 'N/A';
+    value = value[key];
+  }
+  return typeof value === 'string' ? value : JSON.stringify(value);
+}
+
+function replacePlaceholders(text, sources) {
+  return text.replace(/\{\{([^}]+)\}\}/g, (_, placeholder) => {
+    const dot = placeholder.indexOf('.');
+    const sourceId = dot === -1 ? placeholder : placeholder.slice(0, dot);
+    const path = dot === -1 ? '' : placeholder.slice(dot + 1);
+    const source = sources[sourceId];
+    if (!source) return '';
+    if (!source.hasValue) return 'N/A';
+    if (path) {
+      let value = jsonPathValue(source.payload, path);
+      if (value === 'N/A' && source.value) value = jsonPathValue(source.payload, source.value);
+      if (value === 'N/A' && source.type === 'ha' && path !== 'state') value = jsonPathValue(source.payload, 'state');
+      return value;
+    }
+    return source.value ? jsonPathValue(source.payload, source.value) : JSON.stringify(source.payload);
+  });
+}
+
+const manifest = JSON.parse(fs.readFileSync(manifestPath, 'utf8'));
+const sourceId = manifest.sources[0].id;
+const sources = { [sourceId]: { hasValue: true, payload, type: manifest.sources[0].type, value: manifest.sources[0].value } };
+
+console.log(replacePlaceholders(manifest.display.text, sources));
