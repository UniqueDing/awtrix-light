+DisplayManager_::CustomAppInstallResult DisplayManager_::installCustomAppFromJson(const String &name, const char *json)
+{
+  if (LittleFS.exists("/CUSTOMAPPS/" + name + ".json"))
+  {
+    return CUSTOM_APP_INSTALL_DUPLICATE;
+  }
+
+  for (const auto &app : Apps)
+  {
+    if (app.first == name || ((name == "demo-clock" || name == "Demo Clock") && (app.first == "demo-clock" || app.first == "Demo Clock")))
+    {
+      return CUSTOM_APP_INSTALL_DUPLICATE;
+    }
+  }
+
+  DynamicJsonDocument doc(8192);
+  DeserializationError error = deserializeJson(doc, json);
+  if (error || !doc.is<JsonObject>())
+  {
+    doc.clear();
+    return CUSTOM_APP_INSTALL_INVALID_JSON;
+  }
+
+  doc["save"] = true;
+
+  String serializedJson;
+  serializeJson(doc, serializedJson);
+
+  bool installed = parseCustomPage(name, serializedJson.c_str(), false);
+  doc.clear();
+
+  if (!installed)
+  {
+    return CUSTOM_APP_INSTALL_SAVE_FAILED;
+  }
+
+  ui->setApps(Apps);
+  ui->forceResetState();
+
+  return CUSTOM_APP_INSTALL_OK;
+}
