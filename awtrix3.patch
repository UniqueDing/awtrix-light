+#!/usr/bin/env python3
+from pathlib import Path
+import subprocess
+import sys
+
+import_scons_env = globals().get("Import")
+if import_scons_env:
+    import_scons_env("env")
+
+platformio_env = globals().get("env")
+ROOT = Path(platformio_env.subst("$PROJECT_DIR")) if platformio_env else Path(__file__).resolve().parents[1]
+subprocess.run([sys.executable, str(ROOT / "tools/embed_www_assets.py")], check=True)
